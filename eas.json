{
  "build": {
    "preview": {
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "node": "18.18.0",
      "android": {
        "buildType": "apk"
      }, 
      "channel": "preview"
    }, 
    "production": {
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
      },
      "autoIncrement": true,
      "channel": "production", 
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "cli": {
    "appVersionSource": "remote" 
  }
}